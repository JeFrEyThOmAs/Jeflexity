generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  engineType = "client"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}

// defining the schema 

model User {
  id String @id @default(uuid())
  email String 
  provider AuthProvider
  name String
  supabaseId String
  conversations Conversation[]
}

model Conversation {
  id String @id @default(uuid())
  title String?
  slug String
  userId String
  messages Messages[]
  user User @relation(fields: [userId] , references: [id])
}

model Messages {
  id Int @id @default(autoincrement())
  content String
  role MessageRole
  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id])
  createdAt DateTime @default(now())
}

enum MessageRole {
  User 
  Assistant 
}

enum AuthProvider{ 
  Github 
  Google 
}